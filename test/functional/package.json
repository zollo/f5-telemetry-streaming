{
    "name": "f5-telemetry-functional-tests",
    "version": "1.41.0-1",
    "author": "F5, Inc.",
    "license": "Apache-2.0",
    "engines": {
        "node": ">=24",
        "npm": ">=11"
    },
    "scripts": {
        "audit:dev": "npm audit --json | node ../../scripts/npm/better-npm-audit.js",
        "ci:install": "npm ci --omit=dev --omit=optional --install-links",
        "deps:refresh": "npm install --omit=dev --omit=optional --omit=peer --install-links",
        "dev:cleanup": "rm -rf ../artifacts ./node_modules && cd ../packages && for dir in $(ls -d ./*/); do npm --prefix ${dir} run cleanup; done",
        "help": "cat ./scripts/npm/help.txt",
        "preinstall": "../../scripts/npm/check-node-runtime.sh \"24\" \"11\"",
        "postinstall": "./scripts/npm/post-install.sh",
        "test": "mocha \"./testRunner.js\"",
        "test:cloud:azure": "mocha \"./cloud/azureTests.js\"",
        "test:cloud:aws": "mocha \"./cloud/awsTests.js\""
    },
    "dependencies": {
        "@f5-telemetry-tests/common": "file:../packages/common",
        "@f5-telemetry-tests/func-shared": "file:../packages/func-shared",
        "deep-diff": "^1.0.2",
        "kafka-node": "^5.0.0",
        "mocha": "^11.7.5",
        "winston": "^3.19.0"
    },
    "mocha": {
        "reporter": "./reporter.js",
        "retries": 30,
        "slow": 180000,
        "timeout": 300000
    },
    "overrides": {
        "mocha": {
            "diff": "8.0.3"
        }
    }
}
