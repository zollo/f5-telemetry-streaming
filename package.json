{
    "name": "f5-telemetry",
    "version": "1.41.0-1",
    "author": "F5, Inc.",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/F5Networks/f5-telemetry-streaming.git"
    },
    "engines": {
        "node": ">=8.11.1",
        "npm": ">=6"
    },
    "scripts": {
        "audit:all": "exitCode=0; for prefix in ./ application test/unit test/functional; do npm --prefix \"${prefix}\" run audit:dev || exitCode=1; done; exit $exitCode",
        "audit:dev": "npm audit --json | node ./scripts/npm/better-npm-audit.js",
        "audit:prod": "npm --prefix application run ${npm_lifecycle_event}",
        "build": "./scripts/npm/build.sh",
        "ci:all": "npm ci && npm run ci:develop && npm run ci:functest",
        "ci:application": "npm --prefix application run ci:install",
        "ci:develop": "npm ci && npm run ci:application && npm run ci:unit",
        "ci:functest": "npm --prefix test/functional run ci:install",
        "ci:unit": "npm --prefix test/unit run ci:install",
        "deps:refresh": "npm install",
        "dev:cleanup": "rm -rf ./coverage ./node_modules ./nyc_output",
        "dev:cleanup:all": "for prefix in ./ application test/unit test/functional; do npm --prefix \"${prefix}\" run dev:cleanup || exitCode=1; done; exit $exitCode",
        "help": "cat ./scripts/npm/help.txt",
        "lint": "eslint application test",
        "outdated:all": "exitCode=0; for prefix in ./ application test/unit test/functional test/packages/common test/packages/func-shared test/packages/unit-shared; do echo \"List of outdated packages for '${prefix}':\"; npm --prefix \"${prefix}\" outdated || exitCode=1; echo \"\n\n\"; done; exit $exitCode",
        "postinstall": "./scripts/npm/post-install.sh",
        "test": "npm run test:coverage",
        "test:cloud:azure": "npm --prefix test/functional run ${npm_lifecycle_event}",
        "test:cloud:aws": "npm --prefix test/functional run ${npm_lifecycle_event}",
        "test:coverage": "./scripts/npm/run-unit-tests.sh",
        "test:functional": "npm --prefix test/functional run test",
        "test:unit": "./scripts/npm/run-unit-tests.sh",
        "version": "./scripts/npm/version.sh"
    },
    "devDependencies": {
        "@f5devcentral/eslint-config-f5-atg": "^0.1.8",
        "eslint": "8.57.1",
        "eslint-config-airbnb-base": "15.0.0",
        "eslint-plugin-import": "2.32.0",
        "eslint-import-resolver-node": "0.3.9"
    },
    "overrides": {
        "@eslint/eslintrc": {
            "js-yaml": "4.1.1"
        },
        "eslint": {
            "js-yaml": "4.1.1"
        }
    },
    "eslintConfig": {
        "extends": "@f5devcentral/eslint-config-f5-atg",
        "ignorePatterns": [
            "opensource/"
        ],
        "parserOptions": {
            "ecmaVersion": 2018
        },
        "rules": {
            "func-names": "off",
            "max-classes-per-file": "off",
            "no-await-in-loop": "off",
            "prefer-exponentiation-operator": "off",
            "prefer-spread": "off"
        }
    },
    "comments": {
        "devDependencies": {
            "@f5devcentral/eslint-config-f5-atg": "This package is updated on as-needed basis due to the work overhead."
        }
    }
}
